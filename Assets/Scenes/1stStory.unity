  m_Script: {fileID: 11500000, guid: 2851eece094d1c64d9b5d605c5447c7f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::FirstStory
  text:
  - "2026\uB144 \uB178\uC744\uC9C4 \uC5B4\uB290\uB0A0 \uC774\uC81C \uB9C9 \uD1F4\uADFC\uD558\uACE0
    \uC5EC\uC790\uCE5C\uAD6C\uB97C \uB9CC\uB098\uB7EC\uAC00\uB294 \uD55C \uCCAD\uB144\uC774
    \uC788\uB294\uB370..."
  - "\uC5B4 @@\uC57C \uC9C0\uAE08 \uB9C9 \uD68C\uC0AC \uB05D\uB098\uACE0 \uAC00\uB294\uC911\uC774\uC57C~"
  - "\uC544, \uADF8\uB798? \uC54C\uACA0\uC5B4~ \uC5BC\uB978 \uAC08\uAC8C, \uB04A\uC5B4~"
  - "\uD06C\uC544\uC544~ \uB4DC\uB514\uC5B4 @@\uC774\uB791 \uB178\uB294\uAD6C\uB9CC~
    \uBE68\uB9AC \uAC00\uC57C\uC9C0~"
  - "\uC7A0\uC2DC\uD6C4..."
  - "\uC624~ \uC9C0\uD558\uCCA0 \uC0AC\uB78C \uBCC4\uB85C \uC5C6\uACE0~ \uC790\uB9AC\uB3C4
    \uB9CE\uACE0~"
  - "\uADF8\uB7F0\uB370 \uADF8\uB54C..."
  - "\uC57C\uC57C! \uB108 \uB204\uAD6C\uC57C? \uB204\uAD6C\uC57C? \uD6C4\uC544\uC720?
    \uD655 \uC528"
  - "\uC608 \uC800\uC694...?"
  - "\uB108 \uAE4C\uBD88\uB798? \uD655! \uAC04\uC218 \uB208\uAE4C\uB97C \uBF40\uBC14
    \uBC84\uB9B0\uB2E4 \uC26C@\uC250@\uB4DC\uB77C! "
  - "\u3145\u3142 \uBB50\uC57C...?"
  - "\uCF70\uC544\uC544\uC545 \uADF8\uB0E5 \uD655! \uADF8\uB0E5!"
  - "(\uC6C0\uCC14)"
  - "\uC548\uB54C\uB824! \uB09C \uC548\uB54C\uB824!"
  - "\uD558... \uC778\uC0DD"
